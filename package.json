{
  "name": "reviewsense-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm -w apps/web run dev",
    "dev:analysis": "cd apps/analysis-service && uvicorn app.main:app --reload --port 8000",
    "build:web": "npm -w apps/web run build",
    "lint": "npm -w apps/web run lint",
    "test:analysis": "cd apps/analysis-service && pytest"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
