# ============================================================
# ReviewSense AI — Root Environment Variables
# ============================================================
# NEVER commit real keys. Copy this file to .env and fill in values.
# Store production secrets in your platform's secret manager
# (Vercel, Railway, Supabase Vault, etc.)
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=             # https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # Public anon key (safe for frontend)
SUPABASE_SERVICE_ROLE_KEY=            # Service role key — BACKEND ONLY, never expose to frontend

# --- Hugging Face (LLM via OpenAI-compatible router) ---
HF_TOKEN=                             # Fine-grained token with "Inference Providers" permission
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL_NAME=HuggingFaceH4/zephyr-7b-beta:featherless-ai

# --- GitHub OAuth / GitHub App ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=             # Path to .pem file (never commit the file itself)
GITHUB_WEBHOOK_SECRET=

# --- Internal Service Communication ---
ANALYSIS_SERVICE_URL=http://localhost:8000
ANALYSIS_SERVICE_API_KEY=             # Shared secret between BFF and analysis service
