# ============================================================
# ReviewSense AI — Analysis Service (FastAPI / Python)
# ============================================================
# Copy to .env — NEVER commit real keys
# ============================================================

# --- Hugging Face (LLM via OpenAI-compatible router) ---
# Token must have "Inference Providers" permission
# Generate at: https://huggingface.co/settings/tokens
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL_NAME=HuggingFaceH4/zephyr-7b-beta:featherless-ai

# --- Supabase (service role — full DB access) ---
SUPABASE_URL=                          # https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=             # NEVER expose to frontend or logs

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=              # Absolute path to .pem file
GITHUB_WEBHOOK_SECRET=

# --- Service Auth ---
ANALYSIS_SERVICE_API_KEY=              # Shared secret — BFF sends this in Authorization header

# --- Rate Limits ---
RATE_LIMIT_PER_USER_DAILY=50
RATE_LIMIT_PER_ORG_DAILY=200
LLM_MAX_TOKENS_PER_ANALYSIS=4096
